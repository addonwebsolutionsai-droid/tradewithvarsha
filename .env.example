# ============================================================
# HEDGE FUND OS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=4000
CLIENT_PORT=3000
NODE_ENV=development

# ── ENGINE ───────────────────────────────────────────────────

# Signal-engine universe — which equities to scan each tick.
# Anchors (NIFTY, BANKNIFTY, GOLD, CRUDE) are always included.
# Options:
#   CORE10     — 6 hand-picked blue chips (legacy, lightest load)
#   NIFTY50    — Nifty 50 (50 names)
#   NEXT50     — Nifty Next 50 (50 names)
#   NIFTY100   — Nifty 50 + Next 50 (~100 names) [DEFAULT]
#   MIDCAP     — Nifty Midcap 150 (~150 names)
#   SMALLCAP   — Nifty Smallcap 250 (~250 names)
#   CNX500     — Curated CNX 500 (~500 names)
#   NSE_ALL    — Every NSE-EQ scrip via ScripMaster (~1,900 names)
# Stay inside Angel's 60k req/day budget — NIFTY100 ≈ 14k/day at 5-min cadence.
SIGNAL_UNIVERSE=NIFTY100

# Risk profile — winrate (default, asymmetric R:R for ≥80% hit rate)
# or balanced (legacy R:R-skewed). See server/src/engine/risk.ts.
RISK_PROFILE=winrate

# ── TRADING DATA APIs ────────────────────────────────────────

# Alpha Vantage (free: 5 calls/min, 100/day)
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=demo

# Twelve Data (free: 8 calls/min, 800/day)
# Get key: https://twelvedata.com/
TWELVE_DATA_KEY=your_key_here

# Taapi.io (free: 1 call/min — used for advanced indicators)
# Get key: https://taapi.io/
TAAPI_KEY=your_key_here

# Dhan API (NSE live data — free tier available)
# Register: https://api.dhan.co
DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_token

# Upstox API (alternative — free)
# Register: https://upstox.com/developer/
UPSTOX_API_KEY=your_key
UPSTOX_API_SECRET=your_secret

# Financial Modeling Prep (free 250 calls/day)
# Get key: https://financialmodelingprep.com/developer/docs/
FMP_KEY=your_key_here

# ── ASTROLOGY APIs ────────────────────────────────────────────

# AstrologyAPI.com (paid — $10/mo for basic)
# Alternative: Use local Swiss Ephemeris (npm swisseph — free)
ASTRO_API_USER_ID=your_user_id
ASTRO_API_KEY=your_key

# ── BOT TOKENS ────────────────────────────────────────────────

# Telegram Bot Token
# 1. Open Telegram, search @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID(s) — comma separated
# Get your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# WhatsApp via Twilio (optional — paid)
# Alternative: Use Telegram only (simpler)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_ALLOWED=whatsapp:+919XXXXXXXXX

# ── RISK MANAGEMENT ───────────────────────────────────────────
MAX_CAPITAL_PER_TRADE_PCT=5
MAX_OPEN_TRADES=10
MAX_DAILY_LOSS_PCT=2

# ── ALERTS ────────────────────────────────────────────────────
ALERT_ON_NEW_SIGNAL=true
ALERT_MIN_GRADE=B          # Only alert for B and above (A, B)
ALERT_MIN_SCORE=6

# ── BACKTEST ──────────────────────────────────────────────────
BACKTEST_START_DATE=2022-01-01
INITIAL_CAPITAL=1000000

# ── CACHE ─────────────────────────────────────────────────────
PRICE_CACHE_TTL=5
OI_CACHE_TTL=30
SIGNAL_CACHE_TTL=60
